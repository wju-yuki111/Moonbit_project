    "FJD" => Some(fjd)
    "FKP" => Some(fkp)
    "GBP" => Some(gbp)
    "GEL" => Some(gel)
    "GHS" => Some(ghs)
    "GIP" => Some(gip)
    "GMD" => Some(gmd)
    "GNF" => Some(gnf)
    "GTQ" => Some(gtq)
    "GYD" => Some(gyd)
    "HKD" => Some(hkd)
    "HNL" => Some(hnl)
    "HRK" => Some(hrk)
    "HTG" => Some(htg)
    "HUF" => Some(huf)
    "IDR" => Some(idr)
    "ILS" => Some(ils)
    "INR" => Some(inr)
