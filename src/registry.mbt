///|
/// Retrieves the corresponding Currency structure by ISO-4217 code.
/// Returns None if the currency is not registered.
pub fn find_currency(code : String) -> Currency? {
  let upper = code.to_upper()
  match upper {
    "AED" => Some(aed)
    "AFN" => Some(afn)
    "ALL" => Some(all)
    "AMD" => Some(amd)
    "ANG" => Some(ang)
    "AOA" => Some(aoa)
    "ARS" => Some(ars)
    "AUD" => Some(aud)
    "AWG" => Some(awg)
    "AZN" => Some(azn)
    "BAM" => Some(bam)
    "BBD" => Some(bbd)
    "BDT" => Some(bdt)
    "BGN" => Some(bgn)
    "BHD" => Some(bhd)
