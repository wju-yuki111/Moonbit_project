    "BOB" => Some(bob)
    "BRL" => Some(brl)
    "BSD" => Some(bsd)
    "BTN" => Some(btn)
    "BWP" => Some(bwp)
    "BYN" => Some(byn)
    "BZD" => Some(bzd)
    "CAD" => Some(cad)
    "CDF" => Some(cdf)
    "CHF" => Some(chf)
    "CLP" => Some(clp)
    "CNY" => Some(cny)
