    "XPF" => Some(xpf)
    "YER" => Some(yer)
    "ZAR" => Some(zar)
    "ZMW" => Some(zmw)
    "ZWL" => Some(zwl)
    "BTC" => Some(btc)
    "ETH" => Some(eth)
    _ => None
  }
}

///|
/// Checks if a currency code is valid and supported.
pub fn is_valid_currency(code : String) -> Bool {
  match find_currency(code) {
    Some(_) => true
    None => false
  }
}

///|
/// Returns the symbol mapping for common currencies.
pub fn get_currency_symbol(code : String) -> String {
  match find_currency(code) {
    Some(curr) => curr.symbol
    None => code
  }
}
