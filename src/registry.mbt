    "CRC" => Some(crc)
    "CUP" => Some(cup)
    "CVE" => Some(cve)
    "CZK" => Some(czk)
    "DJF" => Some(djf)
    "DKK" => Some(dkk)
    "DOP" => Some(dop)
    "DZD" => Some(dzd)
    "EGP" => Some(egp)
    "ERN" => Some(ern)
    "ETB" => Some(etb)
